ping google.com
warp-cli disconnect 
\
DIRECTION=$1\
\
# 1. Fetch window state from niri in JSON format\
JSON=$(niri msg -j windows)\
\
# 2. Extract current, min, and max column numbers in a single jq pass\
# - We filter windows down to the same workspace as the currently focused window\
# - .layout.pos_in_scrolling_layout[0] represents the column index\
read -r CURRENT MIN MAX <<< $(echo "$JSON" | jq -r '\
    (map(select(.is_focused)) | .[0]) as $focused |\
    if $focused == null or $focused.layout.pos_in_scrolling_layout == null then\
        "null null null"\
    else\
        (map(select(.workspace_id == $focused.workspace_id and .layout.pos_in_scrolling_layout != null)) \
        | map(.layout.pos_in_scrolling_layout[0])) as $cols |\
        "\($focused.layout.pos_in_scrolling_layout[0]) \($cols | min) \($cols | max)"\
    end\
')\
\
# 3. Graceful fallback (e.g. if the focused window is floating, or workspace is empty)\
if [ "$CURRENT" == "null" ]; then\
    if[ "$DIRECTION" == "right" ]; then\
        niri msg action focus-column-right\
    elif[ "$DIRECTION" == "left" ]; then\
        niri msg action focus-column-left\
    fi\
    exit 0\
fi\
\
# 4. Apply Wrap-Around Logic!\
if [ "$DIRECTION" == "right" ]; then\
    # If the current column is equal to or greater than the maximum column\
    if [ "$CURRENT" -ge "$MAX" ]; then\
        niri msg action focus-column-first\
    else\
        niri msg action focus-column-right\
    fi\
\
elif [ "$DIRECTION" == "left" ]; then\
    # If the current column is equal to or less than the minimum column\
    if [ "$CURRENT" -le "$MIN" ]; then\
        niri msg action focus-column-last\
    else\
        niri msg action focus-column-left\
    fi\
fi\

